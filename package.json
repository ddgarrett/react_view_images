{
  "name": "react_view_images",
  "version": "1.0.7",
  "description": "Electron.js Image Viewer Generated by Gemini and Cursor",
  "main": "main.js",
  "type": "commonjs",

  "scripts": {
    "start": "npm run build && electron . && npm run clean:js",

    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",

    "dev": "vite",
    "dev:electron": "electron .",

    "clean:js": "find . -maxdepth 1 -name '*.js' -delete"
  },

  "keywords": [],
  "author": "Doug Garrett",
  "license": "Apache-2.0",

  "dependencies": {
    "exifr": "^7.1.3",
    "exiftool-vendored": "^35.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },

  "devDependencies": {
    "@types/node": "^22.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^40.6.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.3"
  }
}
